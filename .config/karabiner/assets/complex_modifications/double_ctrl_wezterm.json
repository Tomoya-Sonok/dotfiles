{
  "title": "Double Ctrl to Toggle WezTerm",
  "rules": [
    {
      "description": "Double tap Left Ctrl to toggle WezTerm (via Cmd+Shift+Opt+W)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "to_if_alone": [
            {
              "key_code": "left_control"
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "key_code": "w",
                "modifiers": ["left_command", "left_shift", "left_control"]
              }
            ],
            "to_if_canceled": [
              {
                "key_code": "left_control"
              }
            ]
          },
          "conditions": [
            {
              "type": "variable_if",
              "name": "left_ctrl_pressed",
              "value": 1
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            {
              "set_variable": {
                "name": "left_ctrl_pressed",
                "value": 1
              }
            },
            {
              "key_code": "left_control"
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "left_ctrl_pressed",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "left_ctrl_pressed",
                  "value": 0
                }
              }
            ]
          },
          "parameters": {
            "basic.to_delayed_action_delay_milliseconds": 300
          }
        }
      ]
    }
  ]
}
